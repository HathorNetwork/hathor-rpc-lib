# Copy to `.env.e2e` (gitignored) and fill in. Shell env vars override this file.

# --- MetaMask Flask build (pick ONE) ---------------------------------------
# a) Point at an unpacked Flask build you already have:
# E2E_METAMASK_PATH=/absolute/path/to/unpacked/metamask-flask
#
# b) Or download a pinned Flask release (needs curl + unzip):
#    Versions: https://github.com/MetaMask/metamask-extension/releases
#    (assets named metamask-flask-chrome-<version>-flask.0.zip)
# E2E_FLASK_VERSION=

# --- Test wallet -----------------------------------------------------------
# Password used to onboard the throwaway test wallet.
E2E_PASSWORD=Test1234!Test

# --- Run mode --------------------------------------------------------------
# Phase 1 runs headed (interactive). Set E2E_HEADLESS=1 to attempt headless
# (less reliable with MetaMask MV3); `yarn e2e:headed` forces headed.
# E2E_HEADLESS=
#
# Split the MetaMask UI and the Hathor wallet into two side-by-side OS windows
# (instead of tabs in one window) to make a headed run easier to watch. Headed
# only; no-op in headless. Same browser/context — not two browsers.
# E2E_SPLIT_WINDOWS=1

# --- Test wallets ----------------------------------------------------------
# Test wallets are NOT configured here. They live in the committed
# `tests/e2e/wallets.config.json` registry (PUBLIC testnet stub seeds only),
# referenced by name from each Playwright project's `walletSetup`. A `funded`
# stub is already committed there, so the import and feature journeys run by
# default; clear its `funded.srp` to skip them. The onboarding journey needs
# no wallet.

# --- Destination address for send tests (testnet) --------------------------
# E2E_DEST_ADDRESS=
